# MetaTrader 5 Settings
MT5_LOGIN=your_account_number
MT5_PASSWORD=your_password
MT5_SERVER=Vantage-Demo

# Trading Parameters
RISK_PERCENT=0.5
MAX_POSITIONS=2
SYMBOLS=EURUSD,GBPUSD
TIMEFRAME=H1
MIN_BALANCE=250

# Strategy Parameters
EMA_FAST=50
EMA_SLOW=200
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
ATR_PERIOD=14

# Stop Loss & Take Profit
SL_MULTIPLIER=2.0
TP_RATIO=2.0

# Telegram Bot
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_DEBUG=False

# Database
DATABASE_URL=sqlite:///./database/trades.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/trading.log
LOG_FORMAT=json

# Environment
ENVIRONMENT=development
